                "})\n",
                "\n",
                "fig, ax = plt.subplots(figsize=(10, 6))\n",
                "sns.countplot(data=df_stigma, x='Tipo de Saúde', hue='Medo de Consequências', palette='Blues', ax=ax,\n",
